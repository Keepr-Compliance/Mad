# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Supabase Service Role Key (server-side only, NEVER expose to browser)
# Required for impersonation token validation and data loading
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Impersonation Cookie Signing Secret (HMAC-SHA256)
# Must be at least 32 characters (256 bits). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to SUPABASE_SERVICE_ROLE_KEY if not set.
IMPERSONATION_COOKIE_SECRET=your-random-secret-at-least-32-chars

# Admin Portal URL (used for redirect after ending impersonation session)
NEXT_PUBLIC_ADMIN_PORTAL_URL=https://admin.keeprcompliance.com

# Microsoft Clarity (analytics) — optional, omit to disable
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id

# Azure Graph API credentials for sending emails (invite, ticket notifications)
# Requires Azure app registration with Mail.Send application permission + admin consent
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
EMAIL_SENDER_ADDRESS=

# Internal API secret for admin portal → broker portal proxy calls
# Must match the INTERNAL_API_SECRET configured on the admin portal
INTERNAL_API_SECRET=

# Sentry SDK (error tracking — optional, omit to disable)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123.ingest.us.sentry.io/456
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token  # Only needed for source map uploads

# Stripe (BACKLOG-2005a — PAYG per-unlock charging + webhook fulfillment)
# TEST MODE at launch (live account activation is tracked separately).
# Server-side only; NEVER expose the secret or webhook signing secret to the browser.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook endpoint signing secret (differs per environment/endpoint).
# Local dev: stripe listen --forward-to localhost:3001/api/payments/webhook
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_your-webhook-signing-secret

# Cron secret guarding /api/cron/payment-reconcile (Vercel Cron sends this bearer).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-random-cron-secret-at-least-32-chars
