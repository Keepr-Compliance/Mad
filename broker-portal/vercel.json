{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "cd .. && npm ci --ignore-scripts --include=dev",
  "crons": [
    {
      "path": "/api/cron/payment-reconcile",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/email-retry",
      "schedule": "0 4 * * *"
    }
  ]
}
